"use client";

import { useState } from "react";
import Image from "next/image";
import Link from "next/link";
import HeroVideo from "@/components/HeroVideo";
import ScrollFadeIn from "@/components/ScrollFadeIn";
import { models } from "@/lib/models";

export default function Home() {
  const [isFormOpen, setIsFormOpen] = useState(false);
  const [step, setStep] = useState(1);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [isSubmitted, setIsSubmitted] = useState(false);
  
  const featured = models.slice(0, 5);

  const nextStep = () => setStep((s) => s + 1);
  const prevStep = () => setStep((s) => s - 1);

  // FIXED SUBMISSION LOGIC FOR FILES
  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {
    e.preventDefault();
    setIsSubmitting(true);

    // This captures ALL fields including files
    const formData = new FormData(e.currentTarget);

    try {
      const response = await fetch("https://formspree.io/f/mojnpnjo", {
        method: "POST",
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        setIsSubmitted(true);
        setTimeout(() => {
          setIsFormOpen(false);
          setIsSubmitted(false);
          setStep(1);
        }, 6000);
      } else {
        const data = await response.json();
        alert(data.error || "Submission failed. Please check file sizes.");
      }
    } catch (error) {
      alert("Network error. Please try again.");
    } finally {
      setIsSubmitting(false);
    }
  };

  return (
    <main className="-mx-4 flex w-screen flex-col md:-mx-8 lg:-mx-10">
      
      <HeroVideo
        title="Valenté Paris"
        subtitle="Model Agency"
        videoUrl="https://player.vimeo.com/external/434045526.sd.mp4?s=e99f8dbf0278f6184cfef97d65cb658649b57f84&profile_id=164&oauth2_token_id=57447761"
      />

      <section className="bg-white py-20 px-4 md:px-8 lg:px-10 border-b border-[#001F3F]/5">
        <div className="mx-auto max-w-4xl">
          
          {!isFormOpen ? (
            <div className="text-center py-10">
              <ScrollFadeIn>
                <p className="text-[0.62rem] uppercase tracking-[0.4em] text-[#001F3F]/50 mb-4">Join Valenté</p>
                <h2 className="font-brand text-[#001F3F] text-4xl md:text-6xl mb-10 tracking-tight">Get Scouted</h2>
                <button 
                  onClick={() => setIsFormOpen(true)}
                  className="border border-[#001F3F] text-[#001F3F] px-12 py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-[#001F3F] hover:text-white transition-all duration-500"
                >
                  Start Application
                </button>
              </ScrollFadeIn>
            </div>
          ) : isSubmitted ? (
            <div className="animate-in fade-in zoom-in duration-1000 text-center py-24">
              <h2 className="font-brand text-[#001F3F] text-3xl md:text-5xl mb-6 tracking-tight italic">
                Thank you for your application.
              </h2>
              <p className="text-[0.7rem] uppercase tracking-[0.5em] text-[#001F3F]/60">
                Valenté will get in touch with you soon.
              </p>
            </div>
          ) : (
            <div className="animate-in fade-in slide-in-from-bottom-4 duration-700 bg-[#F9F9F9] p-8 md:p-16 border border-[#001F3F]/5">
              
              <div className="flex justify-between items-center mb-12 border-b border-[#001F3F]/10 pb-6">
                <div>
                  <span className="text-[10px] tracking-widest text-[#001F3F]/40 uppercase">Phase {step} of 5</span>
                  <h2 className="text-[#001F3F] text-xl tracking-[0.2em] uppercase font-light mt-1">
                    {step === 1 && "Identity"}
                    {step === 2 && "Measurements (CM)"}
                    {step === 3 && "Polaroids"}
                    {step === 4 && "Management"}
                    {step === 5 && "Agreement"}
                  </h2>
                </div>
                <button onClick={() => {setIsFormOpen(false); setStep(1);}} className="text-[10px] tracking-widest text-[#001F3F]/40 uppercase">Close ✕</button>
              </div>

              <form onSubmit={handleSubmit} className="min-h-[400px] flex flex-col justify-between">
                
                {step === 1 && (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-8 animate-in fade-in duration-500">
                    <input name="First_Name" type="text" placeholder="FIRST NAME" required className="form-input-marine" />
                    <input name="Last_Name" type="text" placeholder="LAST NAME" required className="form-input-marine" />
                    <input name="Age" type="number" placeholder="AGE" required className="form-input-marine" />
                    <input name="Country" type="text" placeholder="COUNTRY" required className="form-input-marine" />
                    <input name="Height_CM" type="text" placeholder="HEIGHT (CM)" required className="form-input-marine" />
                    <select name="Gender" defaultValue="" required className="form-input-marine appearance-none bg-transparent">
                      <option value="" disabled>SEX</option>
                      <option value="Woman">WOMAN</option>
                      <option value="Man">MAN</option>
                      <option value="Non-Binary">NON-BINARY</option>
                    </select>
                  </div>
                )}

                {step === 2 && (
                  <div className="grid grid-cols-2 md:grid-cols-3 gap-8 animate-in fade-in duration-500">
                    <input name="Bust_CM" type="text" placeholder="BUST (CM)" className="form-input-marine" />
                    <input name="Waist_CM" type="text" placeholder="WAIST (CM)" className="form-input-marine" />
                    <input name="Hips_CM" type="text" placeholder="HIPS (CM)" className="form-input-marine" />
                    <input name="Shoes" type="text" placeholder="SHOE SIZE" className="form-input-marine" />
                    <input name="Eyes" type="text" placeholder="EYES" className="form-input-marine" />
                    <input name="Hair" type="text" placeholder="HAIR" className="form-input-marine" />
                  </div>
                )}

                {/* FIXED PHOTO SECTION */}
                {step === 3 && (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6 animate-in fade-in duration-500">
                    {["Portrait", "Headshot", "Full_Figure", "Side_Profile"].map((label) => (
                      <div key={label} className="relative bg-white p-10 border border-[#001F3F]/10 text-center flex flex-col items-center justify-center min-h-[160px]">
                        <p className="text-[10px] tracking-[0.2em] text-[#001F3F]/60 uppercase mb-2">{label.replace("_", " ")}</p>
                        <input 
                          type="file" 
                          name={label} 
                          accept="image/*" 
                          required 
                          className="text-[10px] text-[#001F3F]/40 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-[10px] file:bg-[#001F3F]/5 file:text-[#001F3F] cursor-pointer" 
                        />
                      </div>
                    ))}
                  </div>
                )}

                {step === 4 && (
                  <div className="space-y-12 animate-in fade-in duration-500">
                    <div className="space-y-4">
                      <p className="text-[10px] tracking-widest text-[#001F3F]/60 uppercase">Management Interest</p>
                      <div className="flex gap-8">
                        {["Model", "Talent"].map((type) => (
                          <label key={type} className="flex items-center gap-2 cursor-pointer text-[10px] tracking-widest text-[#001F3F]">
                            <input type="radio" name="Interest" value={type} required /> {type.toUpperCase()}
                          </label>
                        ))}
                      </div>
                    </div>
                  </div>
                )}

                {step === 5 && (
                  <div className="space-y-10 animate-in fade-in duration-500 max-w-2xl">
                    <div className="flex gap-6 items-start">
                      <input type="checkbox" name="Consent_Data" required className="mt-1.5 w-5 h-5 accent-[#001F3F]" />
                      <p className="text-base md:text-lg text-[#001F3F] font-light">
                        I authorize Valenté Paris to process my data for scouting.
                      </p>
                    </div>
                  </div>
                )}

                <div className="flex gap-4 mt-12 pt-8 border-t border-[#001F3F]/10">
                  {step > 1 && !isSubmitting && (
                    <button type="button" onClick={prevStep} className="flex-1 bg-[#E5E5E5] text-[#001F3F] py-5 text-[10px] tracking-[0.3em] uppercase">Back</button>
                  )}
                  {step < 5 ? (
                    <button type="button" onClick={nextStep} className="flex-1 bg-[#E5E5E5] text-[#001F3F] py-5 text-[10px] tracking-[0.3em] uppercase">Next</button>
                  ) : (
                    <button 
                      type="submit" 
                      disabled={isSubmitting}
                      className="flex-1 bg-[#001F3F] text-white py-5 text-[10px] tracking-[0.3em] uppercase flex items-center justify-center gap-3"
                    >
                      {isSubmitting ? "Processing..." : "Submit to Valenté"}
                    </button>
                  )}
                </div>
              </form>
            </div>
          )}
        </div>
      </section>
    </main>
  );
}